# ============================================================================
# CryptoPortfolio
# ============================================================================
# Copy to .env for local dev (VITE_* only) or deployment (all variables).
#
# Infrastructure secrets (GITHUB_TOKEN, DEPLOY_GITHUB_OWNER, DEPLOY_REGISTRY)
# live on the VPS at /etc/businessblok/<service_name>.env — never in the repo.
# ============================================================================


# ============================================================================
# DEPLOYMENT
# ============================================================================

# Target domain (bare hostname, no https://). Used for Ingress + TLS.
DEPLOY_DOMAIN=crypto.example.com


# ============================================================================
# VITE BUILD VARIABLES
# ============================================================================
# Baked into the React build at Docker image creation time (--build-arg).
# Must match vite_args in frontblok.config.json.

# DataBlok API — authentication + CRUD
VITE_DATABASE_API_URL=https://api.example.com

# Google OAuth — must match backend GOOGLE_CLIENT_ID
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
